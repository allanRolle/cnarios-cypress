{
  "devDependencies": {
    "cypress": "^15.12.0",
    "cypress-mochawesome-reporter": "^4.0.2"
  },
  "scripts": {
    "clean:reports": "rm -rf cypress/reports/*",
    "pretest:e2e:ci": "npm run clean:reports",
    "test:e2e:ci": "cypress run --reporter cypress-mochawesome-reporter",
    "test:e2e": "cypress run",
    "test:e2e:open": "cypress open"
  }
}
