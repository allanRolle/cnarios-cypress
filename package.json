{
  "devDependencies": {
    "cypress": "^15.12.0",
    "cypress-mochawesome-reporter": "^4.0.2"
  },
  "scripts": {
    "clean:reports": "rm -rf cypress/reports/*",
    "test:e2e": "npm run clean:reports && cypress run --reporter cypress-mochawesome-reporter",
    "test:e2e:open": "cypress open",
    "test:e2e:headless": "cypress run --headless"
  }
}
